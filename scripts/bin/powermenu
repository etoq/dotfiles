#!/bin/env bash
choice=$(printf "Lock\nLogout\nSuspend\nReboot\nShutdown" | rofi -m -1 -dmenu -p "Система:")

case "$choice" in
  Lock) 
    betterlockscreen -l dimblur ;;
  Logout) 
    i3-msg exit ;; # Если используешь bspwm, замени на bspc quit
  Suspend) 
    betterlockscreen -l dimblur --suspend ;; # Сначала блок, потом сон
  Reboot) 
    systemctl reboot ;;
  Shutdown) 
    systemctl poweroff ;;
esac
