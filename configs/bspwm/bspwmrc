#!/bin/sh
# ~/.config/bspwm/bspwmrc
export DISPLAY=":0"
export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/1000/bus"
export XDG_RUNTIME_DIR="/run/user/1000"
export XDG_CURRENT_DESKTOP="GNOME"

# ── boofer ─────────────────────────────────────────────────────────────────────
pgrep -x greenclip > /dev/null || greenclip daemon &

# ── sxhkd ─────────────────────────────────────────────────────────────────────
pgrep -x sxhkd > /dev/null || sxhkd &

# ── Мониторы ──────────────────────────────────────────────────────────────────
sh $HOME/.config/bspwm/dual_monitors.sh

# ── Рабочие столы (иконки вместо цифр) ───────────────────────────────────────
bspc monitor -d '' '' '' '' '' '' ''

# ── Рамки окон ────────────────────────────────────────────────────────────────
bspc config border_width           2
bspc config normal_border_color    "#44475A"    # Dracula selection
bspc config focused_border_color   "#BD93F9"    # Dracula purple
bspc config active_border_color    "#6272A4"    # Dracula comment
bspc config presel_feedback_color  "#8BE9FD"    # Dracula cyan

# ── Поведение ─────────────────────────────────────────────────────────────────
bspc config focus_follows_pointer  true
bspc config borderless_monocle     true
bspc config gapless_monocle        false

# ── Отступы ───────────────────────────────────────────────────────────────────
bspc config window_gap             10
bspc config top_padding            32          # место для polybar
bspc config left_padding           0
bspc config right_padding          0
bspc config bottom_padding         0

# ── Мышь (mod4 = super) ───────────────────────────────────────────────────────
bspc config pointer_modifier       mod4
bspc config pointer_action1        move
bspc config pointer_action2        resize_side
bspc config pointer_action3        resize_corner

# ── Правила для приложений ────────────────────────────────────────────────────
bspc rule -a kitty:calendar state=floating rectangle=800x500+0+0 center=true
bspc rule -a "otter" state=floating center=true rectangle=500x420+0+0 focus=on 
bspc rule -a "clipboard-manager" state=floating center=true rectangle=600x400+0+0 focus=on
bspc rule -a pkg-manager state=floating center=true rectangle=800x500+0+0
bspc rule -a rednotes-float state=floating center=true rectangle=800x600+0+0

#── Курсор ────────────────────────────────────────────────────────────────────
xsetroot -cursor_name left_ptr

# ── Xresources ────────────────────────────────────────────────────────────────
xrdb merge ~/.Xresources 2>/dev/null

# ── Автозапуск ────────────────────────────────────────────────────────────────
# Обои
sh $HOME/bin/random_wallpaper &

# Polybar
~/.config/polybar/launch.sh &

# Compositor
picom --config $HOME/.config/bspwm/picom_configurations/1.conf &

# Уведомления
dunst -config $HOME/.config/dunst/dunstrc &

# Скриншоты
pkill flameshot; flameshot &

# Батарея
pkill battery-alert; ~/bin/battery-alert &

# XDG portal (нужен для диалогов в браузере)
/usr/lib/xdg-desktop-portal-gtk &
sleep 1
/usr/lib/xdg-desktop-portal &
